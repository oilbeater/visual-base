# Copy to .env and override only the values you care about. Every entry
# below is shown with its built-in default (commented out). Uncomment a
# line only when you want to change it. Never commit the real .env.

# --- Common -----------------------------------------------------------------
# Root directory for all visual-base state (segments, daily logs, understand
# state). BUB_EYE_* path overrides below take precedence over this.
# BUB_HOME=~/.bub

# --- Kimi agent -------------------------------------------------------------
# Two ways to authenticate Kimi:
#   (a) run `kimi login` in the kimi TUI once — kimi-cli uses its own
#       cached credentials and you can leave this section commented out.
#   (b) set an API key via env vars:
# BUB_KIMI_MODEL_NAME=
# BUB_KIMI_API_KEY=
# BUB_KIMI_BASE_URL=

# --- bub-eye: recording (macOS only; Intel + Apple Silicon) -----------------
# On Linux / Windows the channel logs a warning and stays disabled.
# BUB_EYE_ENABLED=true
# Absolute path to a system ffmpeg; blank means "use the bundled imageio-ffmpeg".
# BUB_EYE_FFMPEG=
# Seconds between captured frames (1 = 1 fps; 5 = one frame every 5 s; etc.).
# BUB_EYE_SAMPLE_INTERVAL_SECONDS=1.0
# Segment length in seconds. 900 = 15 minutes per .mp4.
# BUB_EYE_SEGMENT_SECONDS=900
# Forced keyframe every N seconds (bounds P-frame drift, sets seek density).
# BUB_EYE_KEYFRAME_INTERVAL_SECONDS=60
# Encoder. Default uses Apple hardware HEVC; set `libx264` for software fallback.
# BUB_EYE_CODEC=hevc_videotoolbox
# Target bitrate for hardware / bitrate-based codecs (ignored by libx264).
# BUB_EYE_BITRATE=1200k
# Quality for libx264 (ignored by hardware codecs). Lower = better quality.
# BUB_EYE_CRF=28
# Output height in px; -1 disables scaling and keeps native resolution.
# BUB_EYE_SCALE_HEIGHT=720
# avfoundation display index. Blank = auto-detect the first "Capture screen N".
# BUB_EYE_DISPLAY_INDEX=
# Where finalized .mp4 segments land.
# BUB_EYE_SEGMENTS_DIR=~/.bub/eye/segments

# --- bub-eye: auto-understand (video → daily activity log) ------------------
# Set to `false` to just record and skip auto-triggering video-activity-log.
# BUB_EYE_AUTO_UNDERSTAND_ENABLED=true
# One JSON per segment tracking understand status (pending / processing / done).
# BUB_EYE_UNDERSTAND_STATE_DIR=~/.bub/eye/state
# Daily activity logs, one markdown file per date: YYYY-MM-DD.md.
# BUB_EYE_UNDERSTAND_LOGS_DIR=~/.bub/eye/logs
# Seconds between scans of the segments directory.
# BUB_EYE_UNDERSTAND_SCAN_INTERVAL_SECONDS=30.0
# A non-newest segment must be older than this (mtime) to count as finalized.
# BUB_EYE_UNDERSTAND_FINALIZE_GRACE_SECONDS=10.0
# If a segment stays in `processing` longer than this with no output, mark failed.
# BUB_EYE_UNDERSTAND_PROCESSING_TIMEOUT_SECONDS=1200.0
# Base backoff after a failed attempt; effective wait = base * 2^(attempts-1).
# BUB_EYE_UNDERSTAND_RETRY_AFTER_SECONDS=3600.0
# After this many failures the segment is abandoned (terminal `failed`).
# BUB_EYE_UNDERSTAND_MAX_ATTEMPTS=3
# Prompt template injected per segment; `{video}` is replaced with the mp4 path.
# Default is a Chinese template — see `src/bub_eye/settings.py` for the full text.
# BUB_EYE_UNDERSTAND_TRIGGER_PHRASE=
