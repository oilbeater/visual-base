# Copy to .env and fill in. Never commit the real .env.

# --- Kimi (default model plugin) -------------------------------------------
# Reads BUB_KIMI_* via pydantic-settings. The `kimi` CLI must already be on PATH.
# Either run `kimi login` once, or set the three vars below.
BUB_KIMI_MODEL_NAME=
BUB_KIMI_API_KEY=
BUB_KIMI_BASE_URL=

# --- bub-eye (macOS only) --------------------------------------------------
# Intel + Apple Silicon both supported. On Linux / Windows the channel logs
# a warning and stays disabled.
# BUB_EYE_OUTPUT_DIR=~/.visual-base/recordings
# BUB_EYE_SEGMENT_SECONDS=900
